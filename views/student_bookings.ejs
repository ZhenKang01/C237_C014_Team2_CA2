<!DOCTYPE html>
<html lang='en'>
<head><meta charset='UTF-8'><meta name='viewport' content='width=device-width, initial-scale=1.0'><title>My Bookings - TutorLink</title><link rel='stylesheet' href='/css/app.css'></head>
<body class='dashboard-page'>
    <nav class='nav shell'><a class='brand' href='/'><span class='brand-mark'>T</span>TutorLink</a><div class='user-nav'><b class='role-pill student-pill'>Student</b><span><strong><%= user.full_name %></strong><small><%= user.email %></small></span><a class='button secondary' href='/dashboard'>Dashboard</a><a class='button secondary' href='/profile'>Profile</a><a class='button secondary' href='/logout'>Log out</a></div></nav>
    <main class='dashboard shell with-sidebar'>
        <aside class='sidebar'>
            <nav class='sidebar-nav'>
                <a href='/dashboard' class='sidebar-link'>
                    <span class='icon'>🏠</span>
                    Dashboard
                </a>
                <a href='/student/slots' class='sidebar-link'>
                    <span class='icon'>🔍</span>
                    Find Tutors
                </a>
                <a href='/student/my-bookings' class='sidebar-link active'>
                    <span class='icon'>📅</span>
                    My Bookings
                </a>
            </nav>
        </aside>
        <div class='dashboard-content'>
            <% if (errorMessages && errorMessages.length) { %><div class='alert error'><%= errorMessages.join(' ') %></div><% } %>
            <% if (successMessages && successMessages.length) { %><div class='alert success'><%= successMessages.join(' ') %></div><% } %>
            
            <header class='dashboard-header'>
                <div>
                    <span class='eyebrow'>My Bookings</span>
                    <h1>Your Schedule</h1>
                    <p>Keep track of the slots you have booked.</p>
                </div>
            </header>

            <section class='panel'>
                <% if (!bookings || !bookings.length) { %>
                    <div class='empty'>You haven't booked any slots yet. <a href='/student/slots'>Browse available slots</a>.</div>
                <% } else { %>
                    <div class="calendar-container">
                        <div class="calendar-controls">
                            <button id="prev-month" class="nav-btn">&larr; Previous</button>
                            <h2 id="calendar-month-year">Month Year</h2>
                            <button id="next-month" class="nav-btn">Next &rarr;</button>
                        </div>
                        <div class="calendar-header">
                            <div>Sun</div><div>Mon</div><div>Tue</div><div>Wed</div><div>Thu</div><div>Fri</div><div>Sat</div>
                        </div>
                        <div id="calendar-grid" class="calendar-grid">
                            <!-- Calendar days injected via JS -->
                        </div>
                    </div>
                    <div id="booking-modal-overlay" style="display:none; position:fixed; inset:0; background:rgba(15,23,42,0.5); z-index:100; align-items:center; justify-content:center;">
                        <div id="booking-modal" style="background:var(--white); border-radius:var(--radius-lg); box-shadow:var(--shadow-lg); padding:32px; width:min(420px, 90vw); max-height:85vh; overflow-y:auto;">
                            <div id="booking-modal-body"></div>
                        </div>
                    </div>
                    
                    <script>
                        // Inject bookings from EJS to JS safely
                        const bookings = <%- JSON.stringify((bookings || []).map(b => Object.assign({}, b, { slot_time: formatTime(b.slot_time), raw_slot_time: b.slot_time, end_time: formatTime(b.end_time) }))) %>;
                        const modalOverlay = document.getElementById('booking-modal-overlay');
                        const modalBody = document.getElementById('booking-modal-body');

                        function closeBookingModal() {
                            modalOverlay.style.display = 'none';
                            modalBody.innerHTML = '';
                        }

                        modalOverlay.addEventListener('click', (e) => {
                            if (e.target === modalOverlay) closeBookingModal();
                        });

                        function combineDateTime(dateStr, timeStr) {
                            const d = new Date(dateStr);
                            const parts = String(timeStr).split(':').map(Number);
                            d.setHours(parts[0] || 0, parts[1] || 0, parts[2] || 0, 0);
                            return d;
                        }

                        function openBookingModal(evt) {
                            const dateLabel = new Date(evt.slot_date).toLocaleDateString('en-SG', { day: 'numeric', month: 'short', year: 'numeric' });
                            const isPast = combineDateTime(evt.slot_date, evt.raw_slot_time) < new Date();
                            const isFinal = evt.status === 'cancelled' || evt.status === 'rejected';

                            let html = `
                                <h2 style="margin-bottom:4px;">${evt.subject}</h2>
                                <p style="color:var(--muted); margin:0 0 16px;">${dateLabel} &middot; ${evt.slot_time} - ${evt.end_time}</p>
                                <p style="margin:0 0 16px;"><b>Status:</b> <span class="capitalize">${evt.status}</span></p>
                            `;

                            if (evt.status === 'rejected' && evt.reject_reason) {
                                html += `<p style="margin:0 0 16px; color:#b45309;"><b>Teacher's reason:</b> ${evt.reject_reason}</p>`;
                            }
                            if (evt.status === 'cancelled' && evt.student_reason) {
                                html += `<p style="margin:0 0 16px; color:var(--muted);"><b>Your reason:</b> ${evt.student_reason}</p>`;
                            }

                            if (isPast) {
                                html += `<p style="color:var(--muted); font-style:italic;">This session has already passed and can no longer be changed or cancelled.</p>`;
                                html += `<button type="button" class="button secondary full" onclick="closeBookingModal()">Close</button>`;
                            } else if (isFinal) {
                                html += `<button type="button" class="button secondary full" onclick="closeBookingModal()">Close</button>`;
                            } else {
                                html += `
                                    <div style="display:flex; flex-direction:column; gap:12px;">
                                        <a href="/student/bookings/${evt.booking_id}/change" class="button primary full">Change Booking</a>
                                        <button type="button" class="button secondary full" id="show-cancel-form">Cancel Booking</button>
                                        <div id="cancel-reason-block" style="display:none; margin-top:8px;">
                                            <form action="/student/bookings/${evt.booking_id}/cancel" method="POST" class="form-stack" style="gap:12px; margin-top:0;">
                                                <label>
                                                    Reason for Cancelling
                                                    <textarea name="reason" rows="3" placeholder="Let us know why you're cancelling..." required></textarea>
                                                </label>
                                                <button type="submit" class="button primary full">Confirm Cancellation</button>
                                            </form>
                                        </div>
                                        <button type="button" class="button secondary full" onclick="closeBookingModal()">Close</button>
                                    </div>
                                `;
                            }

                            modalBody.innerHTML = html;
                            modalOverlay.style.display = 'flex';

                            const showCancelBtn = document.getElementById('show-cancel-form');
                            if (showCancelBtn) {
                                showCancelBtn.addEventListener('click', () => {
                                    document.getElementById('cancel-reason-block').style.display = 'block';
                                    showCancelBtn.style.display = 'none';
                                });
                            }
                        }
                        let currentDate = new Date();
                        
                        const calendarGrid = document.getElementById('calendar-grid');
                        const monthYearText = document.getElementById('calendar-month-year');
                        
                        function renderCalendar(date) {
                            calendarGrid.innerHTML = '';
                            const year = date.getFullYear();
                            const month = date.getMonth();
                            
                            // Set header text
                            const monthNames = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
                            monthYearText.textContent = `${monthNames[month]} ${year}`;
                            
                            const firstDay = new Date(year, month, 1).getDay();
                            const daysInMonth = new Date(year, month + 1, 0).getDate();
                            
                            // Pad empty days before start of month
                            for (let i = 0; i < firstDay; i++) {
                                const emptyDay = document.createElement('div');
                                emptyDay.className = 'calendar-day empty-day';
                                calendarGrid.appendChild(emptyDay);
                            }
                            
                            const today = new Date();
                            const isCurrentMonth = (today.getFullYear() === year && today.getMonth() === month);
                            
                            // Render actual days
                            for (let day = 1; day <= daysInMonth; day++) {
                                const dayCell = document.createElement('div');
                                dayCell.className = 'calendar-day';
                                
                                if (isCurrentMonth && day === today.getDate()) {
                                    dayCell.classList.add('today');
                                }
                                
                                const dayNum = document.createElement('span');
                                dayNum.className = 'day-number';
                                dayNum.textContent = day;
                                dayCell.appendChild(dayNum);
                                
                                // Find events for this day
                                const dayEvents = bookings.filter(b => {
                                    const bDate = new Date(b.slot_date);
                                    return bDate.getFullYear() === year && bDate.getMonth() === month && bDate.getDate() === day;
                                });
                                
                                dayEvents.forEach(evt => {
                                    const evtEl = document.createElement('div');
                                    evtEl.className = `calendar-event status-${evt.status}`;
                                    evtEl.style.cursor = 'pointer';
                                    evtEl.addEventListener('click', () => openBookingModal(evt));
                                    
                                    const title = document.createElement('span');
                                    title.className = 'event-title';
                                    title.textContent = evt.subject;
                                    
                                    const time = document.createElement('span');
                                    time.className = 'event-time';
                                    time.textContent = evt.slot_time;
                                    
                                    evtEl.appendChild(title);
                                    evtEl.appendChild(time);
                                    
                                    if (evt.status === 'rejected' && evt.reject_reason) {
                                        const reason = document.createElement('small');
                                        reason.style.display = 'block';
                                        reason.style.marginTop = '4px';
                                        reason.style.color = '#b45309';
                                        reason.textContent = "Reason: " + evt.reject_reason;
                                        evtEl.appendChild(reason);
                                    }
                                    
                                    dayCell.appendChild(evtEl);
                                });
                                
                                calendarGrid.appendChild(dayCell);
                            }
                        }
                        
                        document.getElementById('prev-month').addEventListener('click', () => {
                            currentDate.setMonth(currentDate.getMonth() - 1);
                            renderCalendar(currentDate);
                        });
                        
                        document.getElementById('next-month').addEventListener('click', () => {
                            currentDate.setMonth(currentDate.getMonth() + 1);
                            renderCalendar(currentDate);
                        });
                        
                        // Initial render
                        renderCalendar(currentDate);
                    </script>
                <% } %>
            </section>
        </div>
    </main>
</body>
</html>