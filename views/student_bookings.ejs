<!DOCTYPE html>
<html lang='en'>
<head><meta charset='UTF-8'><meta name='viewport' content='width=device-width, initial-scale=1.0'><title>My Bookings - TutorLink</title><link rel='stylesheet' href='/css/app.css'></head>
<body class='dashboard-page'>
    <nav class='nav shell'><a class='brand' href='/'><span class='brand-mark'>T</span>TutorLink</a><div class='user-nav'><b class='role-pill student-pill'>Student</b><span><strong><%= user.full_name %></strong><small><%= user.email %></small></span><a class='button secondary' href='/dashboard'>Dashboard</a><a class='button secondary' href='/profile'>Profile</a><a class='button secondary' href='/logout'>Log out</a></div></nav>
    <main class='dashboard shell'>
        <% if (errorMessages && errorMessages.length) { %><div class='alert error'><%= errorMessages.join(' ') %></div><% } %>
        <% if (successMessages && successMessages.length) { %><div class='alert success'><%= successMessages.join(' ') %></div><% } %>
        
        <header class='dashboard-header'>
            <div>
                <span class='eyebrow'>My Bookings</span>
                <h1>Your Schedule</h1>
                <p>Keep track of the slots you have booked.</p>
            </div>
        </header>

        <section class='panel'>
            <% if (!bookings || !bookings.length) { %>
                <div class='empty'>You haven't booked any slots yet. <a href='/student/slots'>Browse available slots</a>.</div>
            <% } else { %>
                <div class='table-wrap'>
                    <table>
                        <thead>
                            <tr>
                                <th>Teacher</th>
                                <th>Subject & Location</th>
                                <th>Date & Time</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% bookings.forEach(b => { %>
                                <tr>
                                    <td>
                                        <b><%= b.teacher_name %></b>
                                    </td>
                                    <td>
                                        <b><%= b.subject %></b>
                                        <small><%= b.location %></small>
                                    </td>
                                    <td>
                                        <b><%= new Date(b.slot_date).toLocaleDateString() %></b>
                                        <small><%= b.slot_time %></small>
                                    </td>
                                    <td>
                                        <% if (b.status === 'pending') { %>
                                            <span style='color:#b45309;font-weight:600;'>Pending</span>
                                        <% } else if (b.status === 'approved') { %>
                                            <span style='color:var(--green);font-weight:600;'>Approved</span>
                                        <% } else if (b.status === 'rejected') { %>
                                            <span style='color:red;font-weight:600;'>Rejected</span>
                                        <% } else { %>
                                            <span style='color:var(--muted);font-weight:600;'>Cancelled</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <% if (b.status !== 'cancelled' && b.status !== 'rejected') { %>
                                            <form action='/student/bookings/<%= b.booking_id %>/cancel' method='POST' style='display:inline;' onsubmit='return confirm("Cancel this booking?");'>
                                                <button type='submit' class='button secondary' style='min-height:32px;padding:0 12px;font-size:13px;color:red;'>Cancel</button>
                                            </form>
                                        <% } else { %>
                                            -
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </section>
    </main>
</body>
</html>
