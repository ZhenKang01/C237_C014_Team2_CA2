<!DOCTYPE html>
<html lang='en'>
<head><meta charset='UTF-8'><meta name='viewport' content='width=device-width, initial-scale=1.0'><title>Edit Slot - TutorLink</title><link rel='stylesheet' href='/css/app.css'></head>
<body class='dashboard-page'>
    <nav class='nav shell'><a class='brand' href='/'><span class='brand-mark'>T</span>TutorLink</a><div class='user-nav'><b class='role-pill teacher-pill'>Teacher</b><span><strong><%= user.full_name %></strong><small><%= user.email %></small></span><a class='button secondary' href='/teacher/slots'>My Slots</a><a class='button secondary' href='/logout'>Log out</a></div></nav>
    <main class='dashboard shell with-sidebar'>
        <aside class='sidebar'>
            <nav class='sidebar-nav'>
                <a href='/dashboard' class='sidebar-link'>
                    <span class='icon'>🏠</span>
                    Dashboard
                </a>
                <a href='/teacher/slots' class='sidebar-link active'>
                    <span class='icon'>📅</span>
                    My Slots
                </a>
                <a href='/teacher/bookings' class='sidebar-link'>
                    <span class='icon'>📋</span>
                    Student Bookings
                </a>
            </nav>
        </aside>
        <div class='dashboard-content'>
            <% if (errorMessages && errorMessages.length) { %><div class='alert error'><%= errorMessages.join(' ') %></div><% } %>
            <header class='dashboard-header'>
                <div>
                    <span class='eyebrow'>My Slots</span>
                    <h1>Edit Teaching Slot</h1>
                    <p>Update the details of this slot.</p>
                </div>
                <div><a class='button secondary' href='/teacher/slots'>Back to Slots</a></div>
            </header>

            <section class='panel' style='max-width:600px;'>
                <form method='POST' class='form'>
                    <div class='form-group'>
                        <label>Subject</label>
                        <select name='subject' class='input' required>
                            <option value=''>Select a Subject</option>
                            <option value='G133 - Project Communication' <%= slot.subject === 'G133 - Project Communication' ? 'selected' : '' %>>G133 - Project Communication</option>
                            <option value='C202 - Systems Analysis and Design' <%= slot.subject === 'C202 - Systems Analysis and Design' ? 'selected' : '' %>>C202 - Systems Analysis and Design</option>
                            <option value='C203 - Web Application Development' <%= slot.subject === 'C203 - Web Application Development' ? 'selected' : '' %>>C203 - Web Application Development</option>
                            <option value='C206 - Software Development Process' <%= slot.subject === 'C206 - Software Development Process' ? 'selected' : '' %>>C206 - Software Development Process</option>
                            <option value='C236 - Web Security' <%= slot.subject === 'C236 - Web Security' ? 'selected' : '' %>>C236 - Web Security</option>
                            <option value='C237 - Software Application Development' <%= slot.subject === 'C237 - Software Application Development' ? 'selected' : '' %>>C237 - Software Application Development</option>
                            <option value='C240 - Front-End Web Development' <%= slot.subject === 'C240 - Front-End Web Development' ? 'selected' : '' %>>C240 - Front-End Web Development</option>
                            <option value='C300 - Project' <%= slot.subject === 'C300 - Project' ? 'selected' : '' %>>C300 - Project</option>
                        </select>
                    </div>
                    <div class='form-group'>
                        <label>Location</label>
                        <input type='text' name='location' class='input' value='<%= slot.location %>' required>
                    </div>
                    <div class='form-group'>
                        <label>Date</label>
                        <input type='date' name='slot_date' class='input' value='<%= new Date(slot.slot_date).toISOString().split("T")[0] %>' required>
                    </div>
                    <div class='form-row' style='display: flex; gap: 1rem;'>
                        <div class='form-group' style='flex: 1;'>
                            <label>Start Time</label>
                            <input type='time' name='slot_time' class='input' value='<%= slot.slot_time %>' required>
                        </div>
                        <div class='form-group' style='flex: 1;'>
                            <label>End Time</label>
                            <input type='time' name='end_time' class='input' value='<%= slot.end_time %>' required>
                        </div>
                    </div>
                    <button type='submit' class='button primary' style='width:100%'>Update Slot</button>
                </form>
            </section>
        </div>
    </main>
</body>
</html>
