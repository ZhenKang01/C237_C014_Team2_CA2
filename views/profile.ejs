<!DOCTYPE html>
<html lang='en'>
<head><meta charset='UTF-8'><meta name='viewport' content='width=device-width, initial-scale=1.0'><title>My Profile - TutorLink</title><link rel='stylesheet' href='/css/app.css'></head>
<body class='dashboard-page'>
    <nav class='nav shell'>
        <a class='brand' href='/'><span class='brand-mark'>T</span>TutorLink</a>
        <div class='user-nav'>
            <b class='role-pill <%= user.role %>-pill'><%= user.role.charAt(0).toUpperCase() + user.role.slice(1) %></b>
            <span><strong><%= user.full_name %></strong><small><%= user.email %></small></span>
            <a class='button secondary' href='/dashboard'>Dashboard</a>
            <a class='button secondary' href='/logout'>Log out</a>
        </div>
    </nav>
    <main class='dashboard shell'>
        <% if (errorMessages && errorMessages.length) { %><div class='alert error'><%= errorMessages.join(' ') %></div><% } %>
        <% if (successMessages && successMessages.length) { %><div class='alert success'><%= successMessages.join(' ') %></div><% } %>
        
        <header class='dashboard-header'>
            <div>
                <span class='eyebrow'>Settings</span>
                <h1>My Profile</h1>
                <p>Manage your account information.</p>
            </div>
        </header>

        <section class='panel' style='max-width: 600px;'>
            <header>
                <h2>Edit Profile</h2>
                <p>Update your personal details and contact information.</p>
            </header>
            <form action='/profile' method='POST' enctype='multipart/form-data' class='form-stack' style='padding: 24px;'>
                <div style="text-align:center; margin-bottom:24px;">

    <% if (user.profile_image) { %>

        <img
            src="/uploads/<%= user.profile_image %>"
            alt="Profile Picture"
            class="profile-preview">

    <% } else { %>

        <div class="profile-placeholder">
            <%= user.full_name.charAt(0).toUpperCase() %>
        </div>

    <% } %>

    <label style="display:block; margin-top:16px;">
        Profile Picture
        <input
            type="file"
            name="profile_image"
            accept=".jpg,.jpeg,.png,image/*">
    </label>

    <small style="color:var(--muted);">
        JPG or PNG only. Maximum size: 2 MB.
    </small>

</div>

                <div class='form-row'>
                    <label>Full name
                        <input type='text' name='full_name' value='<%= formData.full_name || "" %>' required>
                    </label>
                    <label>Email address
                        <input type='email' name='email' value='<%= formData.email || "" %>' required>
                    </label>
                </div>
                
                <label>Phone number
                    <input type='tel' name='phone_number' value='<%= formData.phone_number || "" %>' required>
                </label>
                
                <label>New Password (optional)
                    <input type='password' name='password' placeholder='Leave blank to keep current password'>
                </label>
                
                <div style='margin-top: 12px;'>
                    <button class='button primary' type='submit'>Save Changes</button>
                    <a class='button secondary' href='/dashboard' style='margin-left: 8px;'>Cancel</a>
                </div>
            </form>
        </section>
    </main>
</body>
</html>
