<!DOCTYPE html>
<html lang='en'>
<head>
    <meta charset='UTF-8'><meta name='viewport' content='width=device-width, initial-scale=1.0'>
    <title>TutorLink - Learn together</title><link rel='stylesheet' href='/css/app.css'>
</head>
<body>
    <nav class='nav shell'>
        <a class='brand' href='/'><span class='brand-mark'>T</span>TutorLink</a>
        <div class='nav-actions'>
            <% if (user) { %><a href='/dashboard'>Dashboard</a><a class='button secondary' href='/logout'>Log out</a>
            <% } else { %><a href='/login'>Log in</a><a class='button primary' href='/register'>Join TutorLink</a><% } %>
        </div>
    </nav>
    <main>
        <section class='hero shell'>
            <div>
                <span class='eyebrow'>One learning community</span>
                <h1>Better support starts with the right connection.</h1>
                <p>TutorLink gives students, teachers, and administrators one clear place to learn, guide, and keep the community running.</p>
                <div class='hero-actions'>
                    <a class='button primary large' href='<%= user ? '/dashboard' : '/register' %>'><%= user ? 'Open my dashboard' : 'Create an account' %></a>
                    <% if (!user) { %><a class='button secondary large' href='/login'>I have an account</a><% } %>
                </div>
            </div>
            <div class='hero-card'>
                <div class='mini-card'><span class='student-avatar'>ST</span><div><b>Students</b><small>Find support and stay on track</small></div></div>
                <div class='mini-card offset-card'><span class='teacher-avatar'>TC</span><div><b>Teachers</b><small>Guide learners with confidence</small></div></div>
                <div class='mini-card'><span class='admin-avatar'>AD</span><div><b>Admins</b><small>Keep every role connected</small></div></div>
            </div>
        </section>
        <section class='roles-section shell'>
            <span class='eyebrow'>Designed around each role</span><h2>One platform. Three focused experiences.</h2>
            <div class='role-grid'>
                <article><span>01</span><h3>Student</h3><p>Learn, get support, and stay on track.</p><b class='role-pill student-pill'>Learn</b></article>
                <article><span>02</span><h3>Teacher</h3><p>Guide students and organise teaching.</p><b class='role-pill teacher-pill'>Guide</b></article>
                <article><span>03</span><h3>Admin</h3><p>Manage users and the community.</p><b class='role-pill admin-pill'>Manage</b></article>
            </div>
        </section>
    </main>
    <footer class='footer shell'><span>TutorLink</span><p>Learning works better together.</p></footer>
</body>
</html>
