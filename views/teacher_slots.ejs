<!DOCTYPE html>
<html lang='en'>
<head><meta charset='UTF-8'><meta name='viewport' content='width=device-width, initial-scale=1.0'><title>My Slots - TutorLink</title><link rel='stylesheet' href='/css/app.css'></head>
<body class='dashboard-page'>
    <nav class='nav shell'><a class='brand' href='/'><span class='brand-mark'>T</span>TutorLink</a><div class='user-nav'><b class='role-pill teacher-pill'>Teacher</b><span><strong><%= user.full_name %></strong><small><%= user.email %></small></span><a class='button secondary' href='/dashboard'>Dashboard</a><a class='button secondary' href='/profile'>Profile</a><a class='button secondary' href='/logout'>Log out</a></div></nav>
    <main class='dashboard shell with-sidebar'>
        <aside class='sidebar'>
            <nav class='sidebar-nav'>
                <a href='/dashboard' class='sidebar-link'>
                    <span class='icon'>🏠</span>
                    Dashboard
                </a>
                <a href='/teacher/slots' class='sidebar-link active'>
                    <span class='icon'>📅</span>
                    My Slots
                </a>
                <a href='/teacher/bookings' class='sidebar-link'>
                    <span class='icon'>📋</span>
                    Student Bookings
                </a>
            </nav>
        </aside>
        <div class='dashboard-content'>
            <% if (errorMessages && errorMessages.length) { %><div class='alert error'><%= errorMessages.join(' ') %></div><% } %>
            <% if (successMessages && successMessages.length) { %><div class='alert success'><%= successMessages.join(' ') %></div><% } %>
            
            <header class='dashboard-header'>
                <div>
                    <span class='eyebrow'>My Slots</span>
                    <h1>Teaching Schedule</h1>
                    <p>Manage your available teaching slots.</p>
                </div>
                <div>
                    <a class='button primary' href='/teacher/slots/new'>+ Add Slot</a>
                </div>
            </header>

            <section class='panel' style='margin-bottom: 24px;'>
                <form action='/teacher/slots' method='GET' class='form'>
                    <div class='form-group'>
                        <label>Search Subject</label>
                        <input type='text' name='subject' class='input' placeholder='Enter subject' value='<%= subject %>'>
                    </div>
                    <div class='form-group'>
                        <label>Filter Location</label>
                        <input type='text' name='location' class='input' placeholder='Enter location' value='<%= location %>'>
                    </div>
                    <div style='margin-top: 16px;'>
                        <button type='submit' class='button primary'>Search</button>
                        <a href='/teacher/slots' class='button secondary' style='margin-left: 8px;'>
                            Clear
                        </a>
                    </div>
                </form>
            </section>

            <section class='panel'>
                <% if (!slots || !slots.length) { %>
                    <div class='empty'>You haven't created any slots yet. <a href='/teacher/slots/new'>Create your first slot</a>.</div>
                <% } else { %>
                    <div class='table-wrap'>
                        <table>
                            <thead>
                                <tr>
                                    <th>Subject & Location</th>
                                    <th>Date & Time</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% slots.forEach(slot => { %>
                                    <tr style="cursor:pointer;" onclick="showBookings('<%= encodeURIComponent(JSON.stringify(slot.booked_students)) %>')">
                                        <td>
                                            <b><%= slot.subject %></b>
                                            <small><%= slot.location %></small>
                                        </td>
                                        <td>
                                            <b><%= new Date(slot.slot_date).toLocaleDateString('en-SG', { day: 'numeric', month: 'short', year: 'numeric' }) %></b>
                                            <small><%= formatTime(slot.slot_time) %> - <%= formatTime(slot.end_time) || '--:--' %></small>
                                        </td>
                                        <td>
                                            <% if (slot.status === 'pending') { %>
                                                <span style="color:var(--primary);font-weight:600;">Pending Admin</span>
                                            <% } else if (slot.status === 'rejected') { %>
                                                <span style="color:red;font-weight:600;">Rejected</span>
                                                <% if (slot.reject_reason) { %>
                                                    <br><small style="color:red;"><%= slot.reject_reason %></small>
                                                <% } %>
                                            <% } else { %>
                                                <% if (slot.is_available) { %>
                                                    <span style="color:var(--green);font-weight:600;">Available</span>
                                                <% } else { %>
                                                    <span style="color:var(--muted);">Unavailable</span>
                                                <% } %>
                                                <br>
                                                <small><%= slot.slots_left %> / <%= slot.capacity %> slots left</small>
                                            <% } %>
                                        </td>
                                        <td onclick="event.stopPropagation();">
                                            <% if (slot.status === 'pending') { %>
                                                <form action='/teacher/slots/<%= slot.slot_id %>/accept' method='POST' style='display:inline;'>
                                                    <button type='submit' class='button primary' style='min-height:32px;padding:0 12px;font-size:13px;'>Accept</button>
                                                </form>
                                                <button type='button' class='button secondary' style='min-height:32px;padding:0 12px;font-size:13px;color:red;' onclick='openRejectModal(<%= slot.slot_id %>)'>Reject</button>
                                            <% } else if (new Date(slot.slot_date) < new Date(new Date().toDateString())) { %>
                                                <span style='color:var(--muted);font-style:italic;'>Inactive</span>
                                            <% } else { %>
                                                <a href='/teacher/slots/<%= slot.slot_id %>/edit' class='button secondary' style='min-height:32px;padding:0 12px;font-size:13px;'>Edit</a>
                                                <form action='/teacher/slots/<%= slot.slot_id %>/delete' method='POST' style='display:inline;' onsubmit='return confirm("Delete this slot?");'>
                                                    <button type='submit' class='button secondary' style='min-height:32px;padding:0 12px;font-size:13px;color:red;'>Delete</button>
                                                </form>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </section>
        </div>
    </main>

    <!-- Students List Modal -->
    <div id="students-modal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; align-items:center; justify-content:center;">
        <div style="background:white; padding:24px; border-radius:8px; width:400px; max-width:90%;">
            <h2 style="margin-top:0;">Booked Students</h2>
            <ul id="modal-student-list" style="margin-top:16px; padding-left: 20px;">
                <!-- Injected via JS -->
            </ul>
            <div style="margin-top:24px; text-align:right;">
                <button type="button" class="button secondary" onclick="document.getElementById('students-modal').style.display = 'none';">Close</button>
            </div>
        </div>


    <!-- Reject Modal -->
    <div id="reject-modal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; align-items:center; justify-content:center;">
        <div style="background:white; padding:32px; border-radius:12px; max-width:400px; width:90%;">
            <h2 style="margin-top:0; color:red;">Reject Slot</h2>
            <form id="reject-form" method="POST" action="">
                <div class="form-group" style="margin-top: 16px;">
                    <label>Reason for Rejection</label>
                    <textarea name="reject_reason" required style="width: 100%; min-height: 80px; padding: 12px; border: 1px solid var(--border); border-radius: 8px;" placeholder="Please provide a reason..."></textarea>
                </div>
                <div style="margin-top:24px; display:flex; justify-content:flex-end; gap: 12px;">
                    <button type="button" class="button secondary" onclick="document.getElementById('reject-modal').style.display = 'none';">Cancel</button>
                    <button type="submit" class="button primary" style="background:red;">Reject Slot</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function showBookings(studentsJson) {
            const students = JSON.parse(decodeURIComponent(studentsJson));
            const list = document.getElementById('modal-student-list');
            list.innerHTML = '';
            
            if (!students || students.length === 0) {
                list.innerHTML = '<li>No students have booked this slot yet.</li>';
            } else {
                students.forEach(s => {
                    const statusText = s.status.charAt(0).toUpperCase() + s.status.slice(1);
                    const color = s.status === 'approved' ? 'var(--green)' : '#b45309';
                    list.innerHTML += `<li style="margin-bottom: 8px;"><b>${s.student_name}</b> <span style="color:${color}; font-size: 12px; font-weight: 600;">(${statusText})</span></li>`;
                });
            }
            document.getElementById('students-modal').style.display = 'flex';
        }

        function openRejectModal(slotId) {
            const modal = document.getElementById('reject-modal');
            const form = document.getElementById('reject-form');
            form.action = '/teacher/slots/' + slotId + '/reject';
            modal.style.display = 'flex';
        }
    </script>
</body>
</html>
