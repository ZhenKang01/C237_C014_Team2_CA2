<!DOCTYPE html>
<html lang='en'>
<head><meta charset='UTF-8'><meta name='viewport' content='width=device-width, initial-scale=1.0'><title>Student Bookings - TutorLink</title><link rel='stylesheet' href='/css/app.css'></head>
<body class='dashboard-page'>
    <nav class='nav shell'><a class='brand' href='/'><span class='brand-mark'>T</span>TutorLink</a><div class='user-nav'><b class='role-pill teacher-pill'>Teacher</b><span><strong><%= user.full_name %></strong><small><%= user.email %></small></span><a class='button secondary' href='/dashboard'>Dashboard</a><a class='button secondary' href='/profile'>Profile</a><a class='button secondary' href='/logout'>Log out</a></div></nav>

    <main class='dashboard shell with-sidebar'>
        <aside class='sidebar'>
            <nav class='sidebar-nav'>
                <a href='/dashboard' class='sidebar-link'>
                    <span class='icon'>🏠</span>
                    Dashboard
                </a>

                <a href='/teacher/slots' class='sidebar-link'>
                    <span class='icon'>📅</span>
                    My Slots
                </a>

                <a href='/teacher/bookings' class='sidebar-link active'>
                    <span class='icon'>📋</span>
                    Student Bookings
                </a>
            </nav>
        </aside>

        <div class='dashboard-content'>
            <% if (errorMessages && errorMessages.length) { %><div class='alert error'><%= errorMessages.join(' ') %></div><% } %>
            <% if (successMessages && successMessages.length) { %><div class='alert success'><%= successMessages.join(' ') %></div><% } %>

            <header class='dashboard-header'>
                <div>
                    <span class='eyebrow'>Approvals</span>
                    <h1>Student Bookings</h1>
                    <p>Review and approve bookings for your slots.</p>
                </div>
            </header>

            <section class='panel' style='margin-bottom: 24px;'>
                <form action='/teacher/bookings' method='GET' class='form'>
                    <div class='form-group'>
                        <label>Search Student</label>
                        <input type='text' name='student' class='input' placeholder='Enter student name' value='<%= student %>'>
                    </div>

                    <div class='form-group'>
                        <label>Filter Status</label>
                        <select name='status' class='input'>
                            <option value='' <%= status === '' ? 'selected' : '' %>>All Statuses</option>
                            <option value='pending' <%= status === 'pending' ? 'selected' : '' %>>Pending</option>
                            <option value='approved' <%= status === 'approved' ? 'selected' : '' %>>Approved</option>
                            <option value='rejected' <%= status === 'rejected' ? 'selected' : '' %>>Rejected</option>
                            <option value='cancelled' <%= status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                        </select>
                    </div>

                    <div style='margin-top: 16px;'>
                        <button type='submit' class='button primary'>Search</button>

                        <a href='/teacher/bookings' class='button secondary' style='margin-left: 8px;'>
                            Clear
                        </a>
                    </div>
                </form>
            </section>

            <section class='panel'>
                <% if (!bookings || !bookings.length) { %>

                    <% if (student || status) { %>
                        <div class='empty'>No matching student bookings were found.</div>
                    <% } else { %>
                        <div class='empty'>No students have booked your slots yet.</div>
                    <% } %>

                <% } else { %>

                    <div class='table-wrap'>
                        <table>
                            <thead>
                                <tr>
                                    <th>Student</th>
                                    <th>Slot Details</th>
                                    <th>Booking Info</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>

                            <tbody>
                                <% bookings.forEach(b => { %>
                                    <tr>
                                        <td>
                                            <b class='capitalize'><%= b.student_name %></b>
                                            <small><%= b.student_email %></small>
                                        </td>

                                        <td>
                                            <b><%= b.subject %></b>
                                            <small><%= new Date(b.slot_date).toLocaleDateString('en-SG', { day: 'numeric', month: 'short', year: 'numeric' }) %> <%= formatTime(b.slot_time) %> - <%= formatTime(b.end_time) %></small>
                                        </td>

                                        <td>


                                            <% if (b.description) { %>
                                                <small style='display: block; margin-top: 4px; color: var(--muted); font-style: italic;'>
                                                    "<%= b.description %>"
                                                </small>
                                            <% } %>
                                            <% if (b.student_reason) { %>
                                                <small style='display: block; margin-top: 4px; color: #b45309;'>
                                                    <b>Student's reason:</b> <%= b.student_reason %>
                                                </small>
                                            <% } %>
                                        </td>

                                        <td>
                                            <% if (b.status === 'pending') { %>
                                                <span style='color:#b45309;font-weight:600;'>Pending</span>
                                            <% } else if (b.status === 'approved') { %>
                                                <span style='color:var(--green);font-weight:600;'>Approved</span>
                                            <% } else { %>
                                                <span style='color:red;font-weight:600;'><%= b.status.charAt(0).toUpperCase() + b.status.slice(1) %></span>
                                            <% } %>
                                        </td>

                                        <td>
                                            <% if (b.status === 'pending') { %>
                                                <div id="actions-<%= b.booking_id %>" style="display:flex; gap: 8px;">
                                                    <form action='/teacher/bookings/<%= b.booking_id %>/status' method='POST'>
                                                        <input type='hidden' name='status' value='approved'>
                                                        <button type='submit' class='button primary' style='min-height:32px;padding:0 12px;font-size:13px;'>Approve</button>
                                                    </form>
                                                    <button type='button' class='button secondary' style='min-height:32px;padding:0 12px;font-size:13px;' onclick="document.getElementById('reject-form-<%= b.booking_id %>').style.display='flex'; document.getElementById('actions-<%= b.booking_id %>').style.display='none';">Reject</button>
                                                </div>
                                                <form id="reject-form-<%= b.booking_id %>" action='/teacher/bookings/<%= b.booking_id %>/status' method='POST' style='display:none; flex-direction:column; gap:4px;'>
                                                    <input type='hidden' name='status' value='rejected'>
                                                    <input type='text' name='reject_reason' placeholder='Reason for rejection (optional)...' style='min-height:32px; padding:0 8px; font-size:13px; width: 200px;'>
                                                    <div style="display:flex; gap: 8px;">
                                                        <button type='submit' class='button primary' style='min-height:32px;padding:0 12px;font-size:13px; background-color:#dc2626;'>Confirm Reject</button>
                                                        <button type='button' class='button secondary' style='min-height:32px;padding:0 12px;font-size:13px;' onclick="document.getElementById('reject-form-<%= b.booking_id %>').style.display='none'; document.getElementById('actions-<%= b.booking_id %>').style.display='flex';">Cancel</button>
                                                    </div>
                                                </form>
                                            <% } else { %>
                                                <small style='color:var(--muted);'>Reviewed</small>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>

                <% } %>
            </section>
        </div>
    </main>
</body>
</html>