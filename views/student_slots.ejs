<!DOCTYPE html>
<html lang='en'>
<head><meta charset='UTF-8'><meta name='viewport' content='width=device-width, initial-scale=1.0'><title>Browse Slots - TutorLink</title><link rel='stylesheet' href='/css/app.css'></head>
<body class='dashboard-page'>
    <nav class='nav shell'><a class='brand' href='/'><span class='brand-mark'>T</span>TutorLink</a><div class='user-nav'><b class='role-pill student-pill'>Student</b><span><strong><%= user.full_name %></strong><small><%= user.email %></small></span><a class='button secondary' href='/dashboard'>Dashboard</a><a class='button secondary' href='/profile'>Profile</a><a class='button secondary' href='/logout'>Log out</a></div></nav>
    <main class='dashboard shell with-sidebar'>
        <aside class='sidebar'>
            <nav class='sidebar-nav'>
                <a href='/dashboard' class='sidebar-link'>
                    <span class='icon'>🏠</span>
                    Dashboard
                </a>
                <a href='/student/slots' class='sidebar-link active'>
                    <span class='icon'>🔍</span>
                    Find Tutors
                </a>
                <a href='/student/my-bookings' class='sidebar-link'>
                    <span class='icon'>📅</span>
                    My Bookings
                </a>
            </nav>
        </aside>
        <div class='dashboard-content'>
            <% if (errorMessages && errorMessages.length) { %><div class='alert error'><%= errorMessages.join(' ') %></div><% } %>
            <% if (successMessages && successMessages.length) { %><div class='alert success'><%= successMessages.join(' ') %></div><% } %>
            
            <header class='dashboard-header'>
                <div>
                    <span class='eyebrow'>Find Tutors</span>
                    <h1>Available Slots</h1>
                    <p>Browse available teaching slots and book them.</p>
                </div>
            </header>
            <section class='panel' style='margin-bottom: 24px;'>
                <form action='/student/slots' method='GET' class='form'>
                    <div class='form-group'>
                        <label>Search Teacher</label>
                        <input type='text' name='teacher' class='input' placeholder='Enter teacher name' value='<%= teacherName %>'>
                    </div>
                    <div class='form-group'>
                        <label>Search Subject</label>
                        <input type='text' name='subject' class='input' placeholder='Enter subject' value='<%= subject %>'>
                    </div>
                    <div class='form-group'>
                        <label>Filter Location</label>
                        <input type='text' name='location' class='input' placeholder='Enter location' value='<%= location %>'>
                    </div>
                    <div style='margin-top: 16px;'>
                        <button type='submit' class='button primary'>Search</button>
                        <a href='/student/slots' class='button secondary' style='margin-left: 8px;'>
                            Clear
                        </a>
                    </div>
                </form>
            </section>
            <section class='panel'>
                <% if (!slots || !slots.length) { %>
                    <div class='empty'>No slots are available right now. Please check back later!</div>
                <% } else { %>
                    <div class='table-wrap'>
                        <table>
                            <thead>
                                <tr>
                                    <th>Teacher</th>
                                    <th>Subject & Location</th>
                                    <th>Date & Time</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% slots.forEach(slot => { %>
                                    <tr>
                                        <td>
                                            <b class="capitalize"><%= slot.teacher_name %></b>
                                        </td>
                                        <td>
                                            <b><%= slot.subject %></b>
                                            <small><%= slot.location %></small>
                                        </td>
                                        <td>
                                            <b><%= new Date(slot.slot_date).toLocaleDateString('en-SG', { day: 'numeric', month: 'short', year: 'numeric' }) %></b>
                                            <small><%= formatTime(slot.slot_time) %> - <%= formatTime(slot.end_time) %></small>
                                        </td>
                                        <td>
                                            <% if (slot.my_status) { %>
                                                <span style='color:var(--green);font-weight:600;'>Booked (<%= slot.my_status %>)</span>
                                            <% } else { %>
                                                <form action='/student/slots/<%= slot.slot_id %>/book' method='POST' style='display:flex; flex-direction:column; gap:8px;'>
                                                    <% const left = Math.max(0, slot.capacity - (slot.booked_slots || 0)); %>
                                                    <div style="display:flex; gap:8px; align-items:center;">
                                                        <small style="font-weight: 600; color: var(--muted);">Slots Left: <%= left %> / <%= slot.capacity %></small>
                                                    </div>
                                                    <% if (left > 0) { %>
                                                        <textarea name='description' placeholder='Add a message (optional)' style='min-height:40px; padding:4px 8px; font-size:13px; font-family:inherit; resize:vertical;'></textarea>
                                                        <button type='submit' class='button primary' style='min-height:32px;padding:0 12px;font-size:13px; align-self:flex-start;'>Book Slot</button>
                                                    <% } else { %>
                                                        <span style='color:#b45309;font-weight:600;font-size:13px;'>Fully Booked</span>
                                                    <% } %>
                                                </form>
                                            <% } %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } %>
            </section>
        </div>
    </main>
</body>
</html>
