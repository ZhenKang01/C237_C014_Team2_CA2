<!DOCTYPE html>
<html lang='en'>
<head><meta charset='UTF-8'><meta name='viewport' content='width=device-width, initial-scale=1.0'><title>Log in - TutorLink</title><link rel='stylesheet' href='/css/app.css'></head>
<body class='auth-page'>
    <a class='brand auth-brand' href='/'><span class='brand-mark'>T</span>TutorLink</a>
    <main class='auth-layout'>
        <section class='auth-copy'><span class='eyebrow'>Welcome back</span><h1>Continue where you left off.</h1><p>Your dashboard automatically adapts to your Student, Teacher, or Admin role.</p></section>
        <section class='form-card'>
            <h2>Log in</h2><p>Enter your account details below.</p>
            <% if (errorMessages.length) { %><div class='alert error'><%= errorMessages.join(' ') %></div><% } %>
            <% if (successMessages.length) { %><div class='alert success'><%= successMessages.join(' ') %></div><% } %>
            <form action='/login' method='POST' class='form-stack'>
                <label>Email address<input type='email' name='email' autocomplete='email' placeholder='you@example.com' required></label>
                <label>Password<input type='password' name='password' autocomplete='current-password' placeholder='Enter your password' required></label>
                <button class='button primary full' type='submit'>Log in</button>
            </form>
            <p class='form-footer'>New to TutorLink? <a href='/register'>Create an account</a></p>
        </section>
    </main>
</body>
</html>
