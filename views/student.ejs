<!DOCTYPE html>
<html lang='en'>
<head><meta charset='UTF-8'><meta name='viewport' content='width=device-width, initial-scale=1.0'><title>Student dashboard - TutorLink</title><link rel='stylesheet' href='/css/app.css'></head>
<body class='dashboard-page'>
    <nav class='nav shell'><a class='brand' href='/'><span class='brand-mark'>T</span>TutorLink</a><div class='user-nav'><b class='role-pill student-pill'>Student</b><span><strong><%= user.username %></strong><small><%= user.email %></small></span><a class='button secondary' href='/logout'>Log out</a></div></nav>
    <main class='dashboard shell'>
        <% if (errorMessages.length) { %><div class='alert error'><%= errorMessages.join(' ') %></div><% } %>
        <% if (successMessages.length) { %><div class='alert success'><%= successMessages.join(' ') %></div><% } %>
        <header class='dashboard-header'><div><span class='eyebrow'>Student workspace</span><h1>Let's keep moving, <%= user.username.split(' ')[0] %>.</h1><p>Your learning support, upcoming activity, and progress start here.</p></div><div class='profile-mark student-avatar'>ST</div></header>
        <section class='welcome student-welcome'><h2>Ask questions. Build confidence. Make progress.</h2><p>This protected dashboard is available only to accounts with the Student role.</p></section>
        <section class='action-grid'>
            <article><span>01</span><h3>Find support</h3><p>Discover learning sessions and connect with a suitable teacher.</p><a class='button secondary' href='/student/sessions' style='margin-top:1rem; display:inline-block; text-decoration:none;'>Browse Sessions</a></article>
            <article><span>02</span><h3>My sessions</h3><p>Keep upcoming bookings and your learning schedule visible.</p><a class='button secondary' href='/student/my-bookings' style='margin-top:1rem; display:inline-block; text-decoration:none;'>My Bookings</a></article>
            <article><span>03</span><h3>My progress</h3><p>Bring your goals, completed learning, and next steps together.</p></article>
        </section>
    </main>
</body>
</html>
