<!DOCTYPE html>
<html lang='en'>
<head><meta charset='UTF-8'><meta name='viewport' content='width=device-width, initial-scale=1.0'><title>Student dashboard - TutorLink</title><link rel='stylesheet' href='/css/app.css'></head>
<body class='dashboard-page'>
    <nav class='nav shell'><a class='brand' href='/'><span class='brand-mark'>T</span>TutorLink</a><div class='user-nav'><b class='role-pill student-pill'>Student</b><span><strong><%= user.full_name %></strong><small><%= user.email %></small></span><a class='button secondary' href='/profile'>Profile</a><a class='button secondary' href='/logout'>Log out</a></div></nav>
    <main class='dashboard shell'>
        <% if (errorMessages.length) { %><div class='alert error'><%= errorMessages.join(' ') %></div><% } %>
        <% if (successMessages.length) { %><div class='alert success'><%= successMessages.join(' ') %></div><% } %>
        <header class='dashboard-header'><div><span class='eyebrow'>Student workspace</span><h1>Let's keep moving, <%= user.full_name.split(' ')[0] %>.</h1><p>Your learning support, upcoming activity, and progress start here.</p></div><div class='profile-mark student-avatar'>ST</div></header>
        <section class='action-grid'>
            <article><span>01</span><h3>Find Tutors</h3><p>Discover learning sessions and connect with a suitable teacher.</p><a class='button secondary' href='/student/slots'>Browse Slots</a></article>
            <article><span>02</span><h3>My Bookings</h3><p>Keep upcoming bookings and your learning schedule visible.</p><a class='button secondary' href='/student/my-bookings'>My Bookings</a></article>
        </section>
    </main>
</body>
</html>
