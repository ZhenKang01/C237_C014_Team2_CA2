<!DOCTYPE html>
<html lang='en'>
<head><meta charset='UTF-8'><meta name='viewport' content='width=device-width, initial-scale=1.0'><title>Create account - TutorLink</title><link rel='stylesheet' href='/css/app.css'></head>
<body class='auth-page'>
    <a class='brand auth-brand' href='/'><span class='brand-mark'>T</span>TutorLink</a>
    <main class='auth-layout'>
        <section class='auth-copy'><span class='eyebrow'>Join the community</span><h1>Make learning feel more connected.</h1><p>Students and teachers can register here. Admin accounts are provisioned separately.</p></section>
        <section class='form-card'>
            <h2>Create your account</h2><p>Tell us a little about yourself.</p>
            <% if (errorMessages.length) { %><div class='alert error'><%= errorMessages.join(' ') %></div><% } %>
            <form action='/register' method='POST' class='form-stack'>
                <div class='form-row'>
                    <label>Full name<input type='text' name='username' value='<%= formData.username || '' %>' required></label>
                    <label>Email address<input type='email' name='email' value='<%= formData.email || '' %>' required></label>
                </div>
                <div class='form-row'>
                    <label>Address<input type='text' name='address' value='<%= formData.address || '' %>' required></label>
                    <label>Contact number<input type='tel' name='contact' value='<%= formData.contact || '' %>' required></label>
                </div>
                <label>Password<input type='password' name='password' minlength='6' placeholder='At least 6 characters' required></label>
                <div class='role-choice'>
                    <label><input type='radio' name='role' value='student' <%= formData.role === 'student' ? 'checked' : '' %> required><span><b>Student</b><small>I want to learn</small></span></label>
                    <label><input type='radio' name='role' value='teacher' <%= formData.role === 'teacher' ? 'checked' : '' %> required><span><b>Teacher</b><small>I want to guide learners</small></span></label>
                </div>
                <button class='button primary full' type='submit'>Create account</button>
            </form>
            <p class='form-footer'>Already registered? <a href='/login'>Log in</a></p>
        </section>
    </main>
</body>
</html>
