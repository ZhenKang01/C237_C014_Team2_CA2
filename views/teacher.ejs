<!DOCTYPE html>
<html lang='en'>
<head><meta charset='UTF-8'><meta name='viewport' content='width=device-width, initial-scale=1.0'><title>Teacher dashboard - TutorLink</title><link rel='stylesheet' href='/css/app.css'></head>
<body class='dashboard-page'>
    <nav class='nav shell'><a class='brand' href='/'><span class='brand-mark'>T</span>TutorLink</a><div class='user-nav'><b class='role-pill teacher-pill'>Teacher</b><span><strong><%= user.full_name %></strong><small><%= user.email %></small></span><a class='button secondary' href='/profile'>Profile</a><a class='button secondary' href='/logout'>Log out</a></div></nav>
    <main class='dashboard shell with-sidebar'>
        <aside class='sidebar'>
            <nav class='sidebar-nav'>
                <a href='/dashboard' class='sidebar-link active'>
                    <span class='icon'>🏠</span>
                    Dashboard
                </a>
                <a href='/teacher/slots' class='sidebar-link'>
                    <span class='icon'>📅</span>
                    My Slots
                </a>
                <a href='/teacher/bookings' class='sidebar-link'>
                    <span class='icon'>📋</span>
                    Student Bookings
                </a>
            </nav>
        </aside>
        <div class='dashboard-content'>
            <% if (errorMessages.length) { %><div class='alert error'><%= errorMessages.join(' ') %></div><% } %>
            <% if (successMessages.length) { %><div class='alert success'><%= successMessages.join(' ') %></div><% } %>
            <header class='dashboard-header'><div><span class='eyebrow'>Teacher workspace</span><h1>Ready to make an impact, <span class="capitalize"><%= user.full_name.split(' ')[0] %></span>?</h1><p>Your dedicated space for guiding students and organising teaching.</p></div><div class='profile-mark teacher-avatar'>TC</div></header>
            
            <section class='stat-grid' style='margin-bottom: 32px;'>
                <article><strong><%= totalSlots %></strong><small>Total Slots</small></article>
                <article><strong><%= pendingBookings %></strong><small>Pending Approvals</small></article>
                <article>
                    <% if (nextSession) { %>
                        <div style="font-size: 16px; font-weight: 700; color: var(--green); margin-bottom: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="<%= nextSession.subject %>"><%= nextSession.subject %></div>
                        <strong><%= new Date(nextSession.slot_date).toLocaleDateString('en-SG', { day: 'numeric', month: 'short', year: 'numeric' }) %></strong>
                        <small>Next Session at <%= formatTime(nextSession.slot_time) %></small>
                    <% } else { %>
                        <strong>None</strong>
                        <small>Next Session</small>
                    <% } %>
                </article>
            </section>
            <section class='panel'>
                <header style="margin-bottom: 24px;">
                    <h2>Confirmed Schedule</h2>
                    <p>Overview of your upcoming approved teaching sessions.</p>
                </header>
                <% if (!bookings || !bookings.length) { %>
                    <div class='empty'>No confirmed bookings yet.</div>
                <% } else { %>
                    <div class="calendar-container">
                        <div class="calendar-controls">
                            <button id="prev-month" class="nav-btn">&larr; Previous</button>
                            <h2 id="calendar-month-year">Month Year</h2>
                            <button id="next-month" class="nav-btn">Next &rarr;</button>
                        </div>
                        <div class="calendar-header">
                            <div>Sun</div><div>Mon</div><div>Tue</div><div>Wed</div><div>Thu</div><div>Fri</div><div>Sat</div>
                        </div>
                        <div id="calendar-grid" class="calendar-grid">
                            <!-- Calendar days injected via JS -->
                        </div>
                    </div>
                    
                    <!-- Booking Details Modal -->
                    <div id="booking-modal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:9999; align-items:center; justify-content:center;">
                        <div style="background:white; padding:24px; border-radius:8px; width:400px; max-width:90%;">
                            <h2 style="margin-top:0;">Booking Details</h2>
                            <div style="margin-top:16px;">
                                <p><strong>Subject:</strong> <span id="modal-subject"></span></p>
                                <p><strong>Location:</strong> <span id="modal-location"></span></p>
                                <p><strong>Date:</strong> <span id="modal-date"></span></p>
                                <p><strong>Time:</strong> <span id="modal-time"></span></p>
                                <hr style="margin: 16px 0; border: none; border-top: 1px solid var(--border);">
                                <h3 style="font-size: 16px; margin-bottom: 8px;">Students (<span id="modal-student-count"></span>)</h3>
                                <ul id="modal-students-list" style="margin: 0; padding-left: 20px; max-height: 200px; overflow-y: auto;">
                                </ul>
                            </div>
                            <div style="margin-top:24px; text-align:right;">
                                <button id="close-modal" class="button secondary">Close</button>
                            </div>
                        </div>
                    </div>

                    <script>
                        const bookings = <%- JSON.stringify(bookings || []) %>;
                        
                        let currentDate = new Date();
                        const calendarGrid = document.getElementById('calendar-grid');
                        const monthYearText = document.getElementById('calendar-month-year');
                        
                        function renderCalendar(date) {
                            calendarGrid.innerHTML = '';
                            const year = date.getFullYear();
                            const month = date.getMonth();
                            
                            const monthNames = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
                            monthYearText.textContent = `${monthNames[month]} ${year}`;
                            
                            const firstDay = new Date(year, month, 1).getDay();
                            const daysInMonth = new Date(year, month + 1, 0).getDate();
                            
                            for (let i = 0; i < firstDay; i++) {
                                const emptyDay = document.createElement('div');
                                emptyDay.className = 'calendar-day empty-day';
                                calendarGrid.appendChild(emptyDay);
                            }
                            
                            const today = new Date();
                            const isCurrentMonth = (today.getFullYear() === year && today.getMonth() === month);
                            
                            for (let day = 1; day <= daysInMonth; day++) {
                                const dayCell = document.createElement('div');
                                dayCell.className = 'calendar-day';
                                
                                if (isCurrentMonth && day === today.getDate()) {
                                    dayCell.classList.add('today');
                                }
                                
                                const dayNum = document.createElement('span');
                                dayNum.className = 'day-number';
                                dayNum.textContent = day;
                                dayCell.appendChild(dayNum);
                                
                                const dayEvents = bookings.filter(b => {
                                    const bDate = new Date(b.slot_date);
                                    return bDate.getFullYear() === year && bDate.getMonth() === month && bDate.getDate() === day;
                                });
                                
                                dayEvents.forEach(evt => {
                                    const evtEl = document.createElement('div');
                                    evtEl.className = `calendar-event status-approved`;
                                    
                                    const title = document.createElement('span');
                                    title.className = 'event-title';
                                    title.textContent = evt.subject;
                                    
                                    const time = document.createElement('span');
                                    time.className = 'event-time';
                                    time.textContent = evt.slot_time;
                                    
                                    const count = document.createElement('span');
                                    count.className = 'event-title';
                                    count.style.fontSize = '11px';
                                    count.style.marginTop = '2px';
                                    count.textContent = evt.students.length + ' student' + (evt.students.length === 1 ? '' : 's');
                                    
                                    evtEl.style.cursor = 'pointer';
                                    evtEl.addEventListener('click', () => {
                                        document.getElementById('modal-subject').textContent = evt.subject;
                                        document.getElementById('modal-location').textContent = evt.location || 'N/A';
                                        document.getElementById('modal-date').textContent = new Date(evt.slot_date).toLocaleDateString('en-SG', { day: 'numeric', month: 'short', year: 'numeric' });
                                        document.getElementById('modal-time').textContent = evt.slot_time;
                                        document.getElementById('modal-student-count').textContent = evt.students.length;
                                        
                                        const list = document.getElementById('modal-students-list');
                                        list.innerHTML = '';
                                        evt.students.forEach(s => {
                                            list.innerHTML += `<li style="margin-bottom: 8px;"><b>${s.name}</b><br><small style="color:var(--muted); font-style:italic;">"${s.message}"</small></li>`;
                                        });
                                        
                                        document.getElementById('booking-modal').style.display = 'flex';
                                    });
                                    
                                    evtEl.appendChild(title);
                                    evtEl.appendChild(time);
                                    evtEl.appendChild(count);
                                    dayCell.appendChild(evtEl);
                                });
                                
                                calendarGrid.appendChild(dayCell);
                            }
                        }
                        
                        document.getElementById('prev-month').addEventListener('click', () => {
                            currentDate.setMonth(currentDate.getMonth() - 1);
                            renderCalendar(currentDate);
                        });
                        
                        document.getElementById('next-month').addEventListener('click', () => {
                            currentDate.setMonth(currentDate.getMonth() + 1);
                            renderCalendar(currentDate);
                        });
                        
                        renderCalendar(currentDate);

                        // Modal close logic
                        document.getElementById('close-modal').addEventListener('click', () => {
                            document.getElementById('booking-modal').style.display = 'none';
                        });
                    </script>
                <% } %>
            </section>
        </div>
    </main>
</body>
</html>
